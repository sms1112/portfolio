import pandas as pd
import sys

def analyze_excel(file_path):
    df = pd.read_excel(file_path) if file_path.endswith('.xlsx') else pd.read_csv(file_path)
    
    print("📈 АНАЛИЗ ФАЙЛА:")
    print(f"Строк: {len(df)}, Столбцов: {len(df.columns)}")
    print("\nТОП-5:")
    print(df.head())
    print("\nСТАТИСТИКА:")
    print(df.describe())
    
    # Сохраняем отчёт
    df.to_csv('analyzed_data.csv', index=False)
    print("\n✅ Сохранено в analyzed_data.csv")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Использование: python excel_analyzer.py файл.xlsx")
    else:
        analyze_excel(sys.argv[1])
